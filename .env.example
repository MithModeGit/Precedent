# Precedent environment variables.
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Gemini API key for all four pipeline passes. Get it from Google AI Studio:
# https://aistudio.google.com
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Supabase project URL. Find it in Supabase: Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous public key. Find it in Supabase: Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
